{
  "name": "kitcn-root-1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:portless",
    "dev:portless": "pnpm run dev:vite:portless & pnpm run dev:convex & wait",
    "dev:vite": "VITE_PORTLESS_URL=${PORTLESS_URL:-} vite dev",
    "dev:vite:portless": "PORTLESS_PORT=${PORTLESS_PORT:-1355} portless run pnpm run dev:vite",
    "dev:convex": "kitcn dev",
    "build": "vite build",
    "build:cloudflare": "sh scripts/cloudflare-build.sh",
    "deploy": "wrangler deploy --config dist/server/wrangler.json --keep-vars",
    "deploy:preview": "sh scripts/cloudflare-preview-upload.sh",
    "preview:name": "sh scripts/preview-name.sh",
    "preview:cleanup": "node scripts/cleanup-stale-previews.mjs",
    "preview:cleanup:cloudflare": "node scripts/cleanup-cloudflare-preview.mjs",
    "preview:cleanup:stale-cloudflare": "node scripts/cleanup-stale-cloudflare-previews.mjs",
    "preview:cleanup:convex": "node scripts/cleanup-convex-preview.mjs",
    "preview:cleanup:stale-convex": "node scripts/cleanup-stale-convex-previews.mjs",
    "cf-typegen": "wrangler types",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit && pnpm run typecheck:convex",
    "codegen": "kitcn codegen",
    "typecheck:convex": "tsc --noEmit --project convex/functions/tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@convex-dev/r2": "^0.10.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@opentelemetry/api": "1.9.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/router-plugin": "^1.166.13",
    "@tiptap/extension-code-block-lowlight": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "better-auth": "1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "1.39.1",
    "hono": "4.12.9",
    "kitcn": "0.15.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-merge-refs": "^3.0.2",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "superjson": "2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-hocus": "^1.0.0",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.38.0",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^27.4.0",
    "portless": "^0.13.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.94.0"
  }
}
